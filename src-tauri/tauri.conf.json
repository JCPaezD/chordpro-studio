{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ChordPro Studio",
  "version": "1.3.2",
  "identifier": "com.jcpaezd.chordprostudio",
  "build": {
    "beforeDevCommand": "npm run dev --prefix app",
    "beforeBuildCommand": "npm run build --prefix app",
    "frontendDist": "../app/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "ChordPro Studio",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../resources/chordpro/": "chordpro/",
      "../resources/chordpro-studio/": "chordpro-studio/"
    }
  }
}
