{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Permissions required by the main window to save exported song files.",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "dialog:allow-save",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        {
          "path": "$HOME/**"
        }
      ]
    }
  ]
}
