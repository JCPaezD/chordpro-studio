// A configuration file for ChordPro.

// See ChordPro website for more details: https://www.chordpro.org/chordpro/chordpro-configuration-file/.
// This is a really relaxed JSON document, see https://metacpan.org/pod/JSON::Relaxed#REALLY-RELAXED-EXTENSIONS

config {
  type        : style
  title       : "ChordPro Studio"
  description : "Project style for ChordPro Studio previews and PDF exports."
}

// Note that this config only contains the differences with the
// default ChordPro config.

settings {

  // Suppress empty chord lines.
  suppress-empty-chords : false

  // Suppress blank lyrics lines.
  suppress-empty-lyrics : false
}

instrument {
  description : "Keyboard, Piano, ..."
  type        : keyboard
}

contents : [
  {

    // An identifying name for this table of contents.
    name : contents_by_title

    // The metadata for this table of contents. One or two items.
    fields : [ artist title ]

    // The label (title) for this table.
    label : "Canciones"

    // The format of the table's lines.
    // You can use all song metadata.
    line : "%{artist} - %{title}"

    // The format for the page number in the table.
    // You can use all song metadata.
    pageno : "%{page}"

    // For future use.
    fold : false

    // If `true`, this table is omitted.
    omit : false

    // The template for this table.
    template : stdtoc

    break : "\\n            %{artist}"
  }
]

// Settings for PDF output.
pdf {

  info {
    title    : "ChordPro Studio Export"
    author   : "ChordPro Studio"
    subject  : "ChordPro lead sheet or songbook export"
    keywords : "ChordPro, chords, lyrics, songbook, piano"
  }

  // Output paper size.
  papersize : "a4"

  // Distance between columns in multi-column mode.
  columnspace : 20

  // Page top margin, excluding `headspace`.
  margintop : 84

  // Page bottom margin, excluding `footspace`.
  marginbottom : 40

  // Page left margin.
  marginleft : 72

  // Page right margin.
  marginright : 40

  // Space reserved for titles on all pages.
  headspace : 66

  // Space for page footers.
  footspace : 20

  // Keep the same header model on all pages.
  head-first-only : false

  // Baseline distances as a factor of the font size.
  spacing {

    // Spacing for page titles.
    title : 1.15

    // Spacing between songlines (grouped chords + lyrics).
    lyrics : 1.2

    // Spacing between chords and lyrics in songlines.
    chords : 1.1

    // Spacing for empty (blank) lines.
    empty : 1.7
  }

  // Appearance of chorus sections.
  chorus {
    indent : 0
    bar {
      offset : 8
      width  : 1
      color  : foreground
    }
  }

  // Render section labels above the section instead of in the margin.
  labels {
    width   : auto
    comment : "comment"
  }

  // Appearance of chord diagrams for string instruments.
  diagrams {
    show : bottom
    linewidth : 0.15
  }

  kbdiagrams {
    show : bottom
  }

  // Page formats.
  formats {
    default.title    : [ "" "%{title}" "" ]
    default.subtitle : [ "" "%{artist}" "" ]
    default.footer   : [ "%{artist}" "%{page}" "%{title}" ]

    first.title      : [ "" "%{title}" "" ]
    first.subtitle   : [ "" "%{artist}" "" ]
    first.footer     : [ "%{artist}" "%{page}" "%{title}" ]

    title.title      : [ "" "%{title}" "" ]
    title.subtitle   : [ "" "%{artist}" "" ]
    title.footer     : [ "%{artist}" "%{page}" "%{title}" ]
  }

  // `fonts` maps output elements to fonts as defined in `fontconfig`.
  fonts {
    title {
      description : "serif bold 16"
    }

    subtitle {
      description : "serif 12"
      color       : foreground-medium
    }

    chord {
      description : "sans bold 11"
      color       : foreground
    }

    comment {
      description : "sans bold 11"
      color       : foreground-medium
      background  : none
    }

    toc : "Times-Roman 15"
  }

  songbook.dual-pages : false
  songbook.sort-songs : false
}
